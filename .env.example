# Cross-device sync via Supabase (optional).
# Copy this file to ".env" and fill in your project's values, or leave it out
# entirely — without these the app saves recipes locally on the device.
#
# These are PUBLIC values (the anon key is meant to ship in client apps).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
